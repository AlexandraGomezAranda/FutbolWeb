36722>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36724>>>>>>>        Boolean bOk bRequireTimeCost
36724>>>>>>>        UChar[] ucaHash
36725>>>>>>>        
36725>>>>>>>        Case Begin
36725>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36727>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36728>>>>>>>                If (not(bOk)) Function_Return False
36731>>>>>>>                
36731>>>>>>>                Move True to bRequireTimeCost
36732>>>>>>>                Case Break
36733>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36736>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36737>>>>>>>                If (not(bOk)) Function_Return False
36740>>>>>>>                
36740>>>>>>>                Move True to bRequireTimeCost
36741>>>>>>>                Case Break
36742>>>>>>>            Case Else
36742>>>>>>>                Error 8710 "Invalid algorithm selected."
36743>>>>>>>>
36743>>>>>>>                Function_Return False
36744>>>>>>>        Case End
36744>>>>>>>        
36744>>>>>>>        String sSalt
36744>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36745>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36748>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36749>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36752>>>>>>>        
36752>>>>>>>        If (bRequireTimeCost) Begin
36754>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36755>>>>>>>        End
36755>>>>>>>>
36755>>>>>>>        Else Begin
36756>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36757>>>>>>>        End
36757>>>>>>>>
36757>>>>>>>        
36757>>>>>>>        Function_Return bOk
36758>>>>>>>    End_Function
36759>>>>>>>    
36759>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36761>>>>>>>        UChar[] ucaSalt
36762>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36763>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36766>>>>>>>        
36766>>>>>>>        If (num_arguments > 4) Begin
36768>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36769>>>>>>>        End
36769>>>>>>>>
36769>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36770>>>>>>>    End_Function
36771>>>>>>>    
36771>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36773>>>>>>>        Boolean bRequiresTimeCost
36773>>>>>>>        UInteger uiAlgo uiTimeCost
36773>>>>>>>        Integer iBegin iEnd
36773>>>>>>>        String sSalt
36773>>>>>>>        
36773>>>>>>>        Move 1 to iBegin
36774>>>>>>>        
36774>>>>>>>        // Parse Algo
36774>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36775>>>>>>>        If (not(iEnd)) Function_Return False
36778>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36779>>>>>>>        
36779>>>>>>>        // Parse Salt
36779>>>>>>>        Move (iEnd + 1) to iBegin
36780>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36781>>>>>>>        If (not(iEnd)) Function_Return False
36784>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36785>>>>>>>        
36785>>>>>>>        Case Begin
36785>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36787>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36790>>>>>>>                Move True to bRequiresTimeCost
36791>>>>>>>                Case Break
36792>>>>>>>            Case Else
36792>>>>>>>                Error 8710 "Invalid algorithm selected."
36793>>>>>>>>
36793>>>>>>>                Function_Return False
36794>>>>>>>        Case End
36794>>>>>>>        
36794>>>>>>>        // Parse optional timecost
36794>>>>>>>        If (bRequiresTimeCost) Begin
36796>>>>>>>            Move (iEnd + 1) to iBegin
36797>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36798>>>>>>>            If (not(iEnd)) Function_Return False
36801>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36802>>>>>>>        End
36802>>>>>>>>
36802>>>>>>>        
36802>>>>>>>        // Parse rest hash
36802>>>>>>>        Move (iEnd + 1) to iBegin
36803>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36804>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36807>>>>>>>        
36807>>>>>>>        // Base64Decode
36807>>>>>>>        UChar[] ucaSalt
36808>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36809>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36812>>>>>>>        
36812>>>>>>>        // Create new hash
36812>>>>>>>        String sNewHash
36812>>>>>>>        If (bRequiresTimeCost) Begin
36814>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36816>>>>>>>                Function_Return False 
36817>>>>>>>            End
36817>>>>>>>>
36817>>>>>>>        End
36817>>>>>>>>
36817>>>>>>>        Else Begin
36818>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36820>>>>>>>                Function_Return False 
36821>>>>>>>            End
36821>>>>>>>>
36821>>>>>>>        End
36821>>>>>>>>
36821>>>>>>>        Function_Return (sNewHash = sHash)
36822>>>>>>>    End_Function
36823>>>>>>>    
36823>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36825>>>>>>>        Boolean bRequireTimeCost
36825>>>>>>>        UBigInt ullSize
36825>>>>>>>        UChar[] ucaSalt
36826>>>>>>>        String sSalt
36826>>>>>>>        
36826>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36827>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36828>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36831>>>>>>>        
36831>>>>>>>        Case Begin
36831>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36833>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36834>>>>>>>                Move True to bRequireTimeCost
36835>>>>>>>                Case Break
36836>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36839>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36840>>>>>>>                Move True to bRequireTimeCost
36841>>>>>>>                Case Break
36842>>>>>>>            Case Else
36842>>>>>>>                Error 8710 "Invalid algorithm selected."
36843>>>>>>>>
36843>>>>>>>                Function_Return 0
36844>>>>>>>        Case End
36844>>>>>>>        
36844>>>>>>>        // calculate base64 in a non-floating-manner
36844>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36845>>>>>>>        
36845>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36846>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36847>>>>>>>        If (bRequireTimeCost) Begin
36849>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36850>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36851>>>>>>>        End
36851>>>>>>>>
36851>>>>>>>        Else Begin
36852>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36853>>>>>>>        End
36853>>>>>>>>
36853>>>>>>>        
36853>>>>>>>        Function_Return ullSize
36854>>>>>>>    End_Function
36855>>>>>>>End_Class
36856>>>>>>>
36856>>>>>>>Class cPasswordHasher is a cObject
36857>>>>>>>    
36857>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36858>>>>>>>    
36858>>>>>>>    Procedure Construct_Object
36860>>>>>>>        Forward Send Construct_Object
36862>>>>>>>        
36862>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36863>>>>>>>        Property UInteger   puiSaltSize         16
36864>>>>>>>        
36864>>>>>>>        Property UInteger   puiOptTimeCost      420000
36865>>>>>>>    End_Procedure
36866>>>>>>>    
36866>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36868>>>>>>>        Boolean bOk
36868>>>>>>>        UInteger uiAlgo
36868>>>>>>>        Get peAlgorithm to uiAlgo
36869>>>>>>>        
36869>>>>>>>        Case Begin
36869>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36871>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36874>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36875>>>>>>>                Case Break
36876>>>>>>>            Case Else
36876>>>>>>>                Error 8710 "Invalid algorithm selected."
36877>>>>>>>>
36877>>>>>>>                Function_Return False
36878>>>>>>>        Case End
36878>>>>>>>        
36878>>>>>>>        Function_Return bOk
36879>>>>>>>    End_Function
36880>>>>>>>    
36880>>>>>>>    Function RequiredBufferSize Returns UBigInt
36882>>>>>>>        UBigInt ullSize
36882>>>>>>>        UInteger uiAlgo
36882>>>>>>>        Get peAlgorithm to uiAlgo
36883>>>>>>>        
36883>>>>>>>        Case Begin
36883>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36885>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36888>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36889>>>>>>>                Case Break
36890>>>>>>>            Case Else
36890>>>>>>>                Error 8710 "Invalid algorithm selected."
36891>>>>>>>>
36891>>>>>>>                Function_Return 0
36892>>>>>>>        Case End
36892>>>>>>>        
36892>>>>>>>        Function_Return ullSize
36893>>>>>>>    End_Function
36894>>>>>>>
36894>>>>>>>End_Class
