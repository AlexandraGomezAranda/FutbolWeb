37939>>>    Procedure SetActionButtons
37942>>>        tWebNavigateData NavigateData
37942>>>        tWebNavigateData NavigateData
37942>>>        Boolean bHasRecord
37942>>>        Handle hoDD
37942>>>
37942>>>        Get Server to hoDD
37943>>>        Get GetNavigateData to NavigateData
37944>>>        Get HasRecord of hoDD to bHasRecord
37945>>>
37945>>>        // let's hide all buttons and then Show the ones we want
37945>>>        WebSet pbRender of oEditBtn to False
37946>>>        WebSet pbRender of oSaveBtn to False
37947>>>        WebSet pbRender of oCancelChangesBtn to False
37948>>>        WebSet pbRender of oDeleteBtn to False
37949>>>
37949>>>        If (NavigateData.bReadOnly) Begin
37951>>>            WebSet pbRender of oEditBtn to True
37952>>>        End
37952>>>>
37952>>>        Else Begin
37953>>>            WebSet pbRender of oSaveBtn to True
37954>>>            WebSet pbRender of oCancelChangesBtn to True
37955>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37956>>>        End
37956>>>>
37956>>>    End_Procedure
