37289>>>    Procedure DoLogin
37292>>>        String sLoginName sPassword sPrevStateHash
37292>>>        Boolean bResult
37292>>>        
37292>>>        WebGet psValue of oLoginName to sLoginName
37293>>>        WebGet psValue of oPassword to sPassword
37294>>>        
37294>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37295>>>        
37295>>>        If (bResult) Begin
37297>>>            Send Hide of oLogin
37298>>>            Send ShowHeader of ghoWebApp
37299>>>            WebSet psCSSClass of ghoWebApp to ""
37300>>>            
37300>>>            WebGet psPrevStateHash to sPrevStateHash
37301>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37302>>>            
37302>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37302>>>            WebSet psValue of oLoginName to ""
37303>>>            WebSet psValue of oPassword  to ""
37304>>>            WebSet pbVisible of oWarning to False
37305>>>        End
37305>>>>
37305>>>        Else Begin
37306>>>            WebSet pbVisible of oWarning to True
37307>>>        End
37307>>>>
37307>>>    End_Procedure
37308>>>    
37308>>>    Procedure OnSubmit
37311>>>        Send DoLogin
37312>>>    End_Procedure
37313>>>    
37313>>>    Procedure OnLoad
37316>>>        String sPrevStateHash sView
37316>>>        
37316>>>        Forward Send OnLoad
37318>>>        
37318>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37318>>>        Get StateHash of ghoWebApp to sPrevStateHash
37319>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37320>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37322>>>            WebSet psPrevStateHash to sPrevStateHash
37323>>>        End
37323>>>>
37323>>>        
37323>>>    End_Procedure
