37609>>>        WebSet pbRender of oEditBtn to False
37610>>>        WebSet pbRender of oSaveBtn to False
37611>>>        WebSet pbRender of oCancelChangesBtn to False
37612>>>        WebSet pbRender of oDeleteBtn to False
37613>>>
37613>>>        If (NavigateData.bReadOnly) Begin
