38885>>>        WebSet pbRender of oEditBtn to False
38886>>>        WebSet pbRender of oSaveBtn to False
38887>>>        WebSet pbRender of oCancelChangesBtn to False
38888>>>        WebSet pbRender of oDeleteBtn to False
38889>>>
38889>>>        If (NavigateData.bReadOnly) Begin
38891>>>            WebSet pbRender of oEditBtn to True
38892>>>        End
38892>>>>
38892>>>        Else Begin
38893>>>            WebSet pbRender of oSaveBtn to True
38894>>>            WebSet pbRender of oCancelChangesBtn to True
38895>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38896>>>        End
38896>>>>
